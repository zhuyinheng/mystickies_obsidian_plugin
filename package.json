{
	"name": "mystickies",
	"version": "0.1.0",
	"description": "Always-on-top floating sticky windows for Obsidian notes.",
	"main": "dist/main.js",
	"scripts": {
		"dev": "node scripts/esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node scripts/esbuild.config.mjs production",
		"release:check": "npm run build && node scripts/release-check.mjs",
		"vault": "open -a Obsidian /Users/zhuyinheng/obsidian_test_vault",
		"snap": "screencapture -x /tmp/mystickies-snap.png && echo \"Saved to /tmp/mystickies-snap.png\""
	},
	"keywords": [],
	"author": "zhuyinheng",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.21.0",
		"obsidian": "^1.5.7",
		"tslib": "^2.6.2",
		"typescript": "^5.4.0"
	},
	"dependencies": {
		"obsidian-daily-notes-interface": "^0.9.4"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/zhuyinheng/mystickies_obsidian_plugin.git"
	}
}
